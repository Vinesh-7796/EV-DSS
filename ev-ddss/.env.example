# =============================================================================
# EV Diagnostic Decision Support System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME=EV-DDSS
APP_VERSION=0.1.0
APP_DEBUG=false
LOG_LEVEL=INFO

# --- PostgreSQL ---
DATABASE_URL=postgresql://user:password@localhost:5432/ev_ddss

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_TIMEOUT=30

# --- Future: Embedding Model ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_DEVICE=cpu

# --- Future: LLM ---
LLM_MODEL=llama-3.2-3b-instruct
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_DEVICE=cpu
LLM_CONTEXT_LENGTH=8192

# --- Future: Data Paths ---
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed
DATA_EMBEDDINGS_PATH=./data/embeddings
DATA_IMAGES_PATH=./data/images
DATA_CACHE_PATH=./data/cache
